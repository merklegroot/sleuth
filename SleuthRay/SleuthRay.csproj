<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Raylib-cs" Version="5.0.0" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\wanderer_talk.json" LogicalName="wanderer_talk.json" />
    <EmbeddedResource Include="Resources\gunshot.wav" LogicalName="gunshot.wav" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="assets\gamecontrollerdb_xbox_mac.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
